# Wrangler injects these into the Worker at *runtime* (`wrangler dev` / `opennextjs-cloudflare preview`).
# `open-next.config.ts` reads OPENNEXT_* here — shell `cross-env` on `yarn preview` only affects the Node
# build process, so without this file the worker still uses sharded DO tag cache → prefetch 500s locally.
OPENNEXT_PREVIEW_DISABLE_INC_CACHE=1
OPENNEXT_DISABLE_REGIONAL_CACHE=1
REPRO_RESPONSE_KB=64
# Avoid two parallel huge RSC payloads on /nested-stream (Chrome “page couldn’t load” at 200).
REPRO_NESTED_STREAM_SERIAL_COLUMNS=1

# Uncomment for `yarn preview:timing` phase logs inside the worker:
# REPRO_TIMING=1
